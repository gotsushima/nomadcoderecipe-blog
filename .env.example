# Supabase (サーバーサイドのみ — 絶対にフロントエンドに露出させない)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Revalidate Webhook シークレット (HMAC検証用)
REVALIDATE_SECRET=your-random-secret-min-32-chars

# Cron認証トークン (Vercel Cronからのリクエスト検証)
CRON_SECRET=your-random-secret-min-32-chars

# ─── 日刊まとめ生成 (run-digest.ts) ──────────────────────────

# Anthropic API キー (必須)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ElevenLabs 音声生成 (任意 — 未設定時は音声生成をスキップ)
ELEVENLABS_API_KEY=sk_...
# 使用する音声ID (省略時は Rachel: pNInz6obpgDQGcFmaJgB)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
