# Supabase (サーバーサイドのみ — 絶対にフロントエンドに露出させない)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Revalidate Webhook シークレット (HMAC検証用)
REVALIDATE_SECRET=your-random-secret-min-32-chars

# Cron認証トークン (Vercel Cronからのリクエスト検証)
CRON_SECRET=your-random-secret-min-32-chars
